# 💸 Finova - Local Development Environment Variables

# Database Credentials (docker-compose & spring.datasource)
MYSQL_ROOT_PASSWORD=Pruthvi@2324
MYSQL_DATABASE=finance_tracker
MYSQL_USER=root
MYSQL_PASSWORD=Pruthvi@2324

# Spring Boot Application Settings
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/finance_tracker?createDatabaseIfNotExist=true&useSSL=false
# If using Docker Compose, use 'db' instead of 'localhost'
# SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/finance_tracker?createDatabaseIfNotExist=true&useSSL=false

# Security
# Set this to a long random hexadecimal string in production!
JWT_SECRET=change_this_in_production_to_a_long_random_string
JWT_EXPIRATION=86400000

# Backend Server Port
SERVER_PORT=8081

# Google AI Assistant (Gemini API)
# Get your FREE key from Google AI Studio: https://aistudio.google.com/
# Use the 'Gemini 1.5 Flash' model for best results.
AI_GEMINI_API_KEY=your_gemini_api_key_here

# Frontend Configuration (React + Vite)
# This URL points the frontend to the backend API.
VITE_API_URL=http://localhost:8081/api

