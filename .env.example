# Database Credentials (used by docker-compose)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=finance_tracker
MYSQL_USER=user
MYSQL_PASSWORD=password

# Spring Boot Application Settings
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/finance_tracker?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# Security
# Set this to a long random string in production!
JWT_SECRET=changeme123changeme123changeme123changeme123
JWT_EXPIRATION=86400000

# Server port
PORT=8080

# External APIs
# Get your key from Google AI Studio: https://aistudio.google.com/
AI_GEMINI_API_KEY=your_gemini_api_key_here

# Local Dev Vite Settings
VITE_API_URL=http://localhost:8080/api
